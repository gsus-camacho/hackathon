---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.tsx";
import BenchmarkChart from "../components/BenchmarkChart.tsx";
import SatisfactionTable from "../components/SatisfactionTable.tsx";
import SchoolsRanking from "../components/SchoolsRanking.tsx";
import { serverGet, formatCurrency } from "../lib/api";
import { TrendingUp, ShoppingCart, Trash2, Clock, Building2, Database, Star } from "lucide-react";

const B2B_DAYS = 90;
const b2b = await serverGet(`/statistics/b2b?days=${B2B_DAYS}`);

const benchmarkData = (b2b.benchmark || []).map((item: any) => ({
  product: item.product,
  delta: item.delta,
}));

const satisfactionData = (b2b.satisfaction || [])
  .filter((item: any) => item.total_votes > 0)
  .slice(0, 12)
  .map((item: any) => ({
    product: item.product,
    si: item.si,
    action: item.action as "Mantener" | "Revisar" | "Descontinuar",
  }));

const schoolsData = b2b.schools || [];
const summary = b2b.summary || {};

// Derived KPIs
const totalSchools = summary.total_schools || 0;
const totalRecords = summary.total_records || 0;
const avgSi = summary.avg_si || 0;
const totalStudents = summary.total_students || 0;
const totalProducts = summary.total_products || 0;
const totalRevenue = summary.total_revenue || 0;
const analysisDays = summary.days || 90;

// Format large numbers
function compactNum(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
  return n.toLocaleString("es-CO");
}
---
<Layout title="Benchmark B2B" active="benchmark" description="Pilar 03 · Inteligencia B2B">
  <div class="mb-6 animate-fade-up">
    <h1 class="font-heading text-3xl sm:text-4xl font-semibold tracking-tight text-bio-900">
      Inteligencia B2B sobre datos propietarios
    </h1>
    <p class="text-bio-500 text-sm mt-1 max-w-3xl">
      Triangulación de volumen histórico × Satisfaction Index con datos reales de la red.
      Últimos <strong class="text-bio-700">{analysisDays} días</strong> de transacciones.
    </p>
  </div>

  <!-- Triangulation hero -->
  <section class="relative overflow-hidden rounded-2xl bg-bio-900 text-bio-100 p-6 mb-6 grain" data-testid="benchmark-hero">
    <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div>
        <span class="text-[10px] uppercase tracking-[0.25em] font-mono text-bio-500">Pilar 03 · Núcleo de monetización</span>
        <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-white mt-2 max-w-xl">
          Volumen histórico × satisfacción cualitativa.
        </h2>
        <p class="text-sm text-bio-200 mt-2 max-w-xl">
          <strong class="text-white font-mono">{compactNum(totalRecords)}</strong> registros transaccionales propietarios de
          <strong class="text-white font-mono">{totalSchools}</strong> colegios, cruzados con feedback directo de los padres.
          Barrera de entrada que ningún competidor reciente puede replicar.
        </p>
      </div>
      <div class="flex flex-col gap-2">
        <div class="inline-flex items-center gap-2 bg-white/10 rounded-lg px-4 py-2 text-sm text-white">
          <ShoppingCart class="h-4 w-4" /> Qué comprar
        </div>
        <div class="inline-flex items-center gap-2 bg-white/10 rounded-lg px-4 py-2 text-sm text-white">
          <Trash2 class="h-4 w-4" /> Qué descontinuar
        </div>
        <div class="inline-flex items-center gap-2 bg-white/10 rounded-lg px-4 py-2 text-sm text-white">
          <Clock class="h-4 w-4" /> Cuándo reabastecer
        </div>
      </div>
    </div>
  </section>

  <!-- KPI cards row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="rounded-xl border border-bio-200 bg-white p-5" data-testid="kpi-benchmark-schools">
      <div class="flex items-center gap-2 mb-2">
        <Building2 class="h-4 w-4 text-blue-500" />
        <span class="text-[10px] uppercase tracking-[0.18em] text-bio-500 font-mono">Colegios en red</span>
      </div>
      <div class="font-heading text-3xl font-semibold text-bio-900">{totalSchools}</div>
      <p class="text-xs text-bio-500 mt-1">Participando activamente en la red</p>
    </div>
    <div class="rounded-xl border border-bio-200 bg-white p-5" data-testid="kpi-benchmark-records">
      <div class="flex items-center gap-2 mb-2">
        <Database class="h-4 w-4 text-emerald-500" />
        <span class="text-[10px] uppercase tracking-[0.18em] text-bio-500 font-mono">Registros analizados</span>
      </div>
      <div class="font-heading text-3xl font-semibold text-bio-900">{compactNum(totalRecords)}</div>
      <p class="text-xs text-bio-500 mt-1">Transacciones en {analysisDays} días</p>
    </div>
    <div class="rounded-xl border border-bio-200 bg-white p-5" data-testid="kpi-benchmark-si">
      <div class="flex items-center gap-2 mb-2">
        <Star class="h-4 w-4 text-amber-500" />
        <span class="text-[10px] uppercase tracking-[0.18em] text-bio-500 font-mono">SI promedio red</span>
      </div>
      <div class="font-heading text-3xl font-semibold text-bio-900">{avgSi.toFixed(2)}</div>
      <p class="text-xs text-bio-500 mt-1">Satisfacción compuesta</p>
    </div>
    <div class="rounded-xl border border-bio-200 bg-white p-5" data-testid="kpi-benchmark-revenue">
      <div class="flex items-center gap-2 mb-2">
        <TrendingUp class="h-4 w-4 text-violet-500" />
        <span class="text-[10px] uppercase tracking-[0.18em] text-bio-500 font-mono">Revenue total</span>
      </div>
      <div class="font-heading text-2xl font-semibold text-bio-900">{formatCurrency(totalRevenue)}</div>
      <p class="text-xs text-bio-500 mt-1">{compactNum(totalStudents)} estudiantes · {totalProducts} productos</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Benchmark Nacional -->
    <Card title="Benchmark Nacional" description={`vs. ${totalSchools} colegios · delta % sobre mediana de la red`}>
      <BenchmarkChart data={benchmarkData} client:visible />
    </Card>

    <!-- Satisfaction Index -->
    <Card title="Satisfaction Index" description="SI = votos positivos / total · datos de feedback real">
      <SatisfactionTable data={satisfactionData} client:visible />
    </Card>
  </div>

  <!-- Schools ranking -->
  <Card title="Ranking de Colegios" description={`Top colegios por revenue en ${analysisDays} días`} className="mb-6">
    <SchoolsRanking data={schoolsData} days={analysisDays} client:visible />
  </Card>

  <!-- Data provenance footer -->
  <div class="rounded-xl border border-bio-100 bg-bio-50/50 p-4 text-center">
    <p class="text-xs text-bio-500 font-mono">
      Datos extraídos de <strong>hackaton_ventas</strong> + <strong>hackaton_recargas</strong> + <strong>product_votes</strong> ·
      PostgreSQL · Período: últimos {analysisDays} días · Actualización: en tiempo real
    </p>
  </div>
</Layout>
