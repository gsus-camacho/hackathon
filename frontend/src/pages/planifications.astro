---
import Layout from "../layouts/Layout.astro";
import MealPlanner from "../components/MealPlanner.tsx";
import { PUBLIC_BACKEND_URL } from "../lib/api";
---
<Layout title="Planificaciones" active="planifications" description="Weekly meal scheduling">
  <div class="mb-6">
    <h1 class="font-heading text-3xl font-semibold tracking-tight text-bio-900">Planificaciones semanales</h1>
    <p class="text-bio-500 text-sm mt-1">
      Asigna productos a cada hijo durante la semana. Al alcanzar el presupuesto mínimo, se desbloquea una recompensa.
    </p>
  </div>
  <MealPlanner apiBase={PUBLIC_BACKEND_URL} client:load />
</Layout>
