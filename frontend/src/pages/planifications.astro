---
import Layout from "../layouts/Layout.astro";
import AtRiskLoader from "../components/AtRiskLoader.tsx";
import { PUBLIC_BACKEND_URL } from "../lib/api";
---
<Layout title="Planificaciones" active="planifications" description="Balance prediction">
  <div class="mb-6 flex items-end justify-between">
    <div>
      <h1 class="font-heading text-3xl font-semibold tracking-tight text-bio-900">Planificaciones</h1>
      <p class="text-bio-500 text-sm mt-1">Predicción de saldo y estudiantes en riesgo.</p>
    </div>
  </div>
  <AtRiskLoader apiBase={PUBLIC_BACKEND_URL} client:load />
</Layout>
