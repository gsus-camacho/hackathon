---
import Layout from "../layouts/Layout.astro";
import PackageList from "../components/PackageList.tsx";
import { serverGet, PUBLIC_BACKEND_URL } from "../lib/api";

let pkgs: any[] = [];
try {
  pkgs = await serverGet("/discounts/packages");
} catch {}
---
<Layout title="Paquetes Dinámicos" active="discounts" description="Pilar 01 · Flujo de caja anticipado">
  <div class="mb-6">
    <h1 class="font-heading text-3xl font-semibold tracking-tight text-bio-900">Paquetes Dinámicos</h1>
    <p class="text-bio-500 text-sm mt-1">
      Paquetes semanales y mensuales con incentivo configurable por la cafetería. Capital anticipado + optimización de inventario.
    </p>
  </div>
  <PackageList apiBase={PUBLIC_BACKEND_URL} initial={pkgs} client:load />
</Layout>
