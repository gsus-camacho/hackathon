---
import Layout from "../layouts/Layout.astro";
import RecommendationsPanel from "../components/RecommendationsPanel.tsx";
import { serverGet, PUBLIC_BACKEND_URL } from "../lib/api";

let recs: any[] = [];
try { recs = await serverGet("/recommendations/"); } catch {}
---
<Layout title="Recomendaciones IA" active="recommendations" description="Gemini">
  <header class="mb-6">
    <h1 class="font-heading text-3xl font-semibold tracking-tight text-bio-900">Recomendaciones IA</h1>
    <p class="text-bio-500 text-sm mt-1">
      Gemini analiza productos nuevos y genera insights de revenue, nutrición y seguridad.
    </p>
  </header>
  <RecommendationsPanel apiBase={PUBLIC_BACKEND_URL} initial={recs} client:load />
</Layout>
